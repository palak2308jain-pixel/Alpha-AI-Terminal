# ══════════════════════════════════════════════════════════════════════════════
# AI-TRADER — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# Every variable listed here is actively referenced by at least one service.
# ══════════════════════════════════════════════════════════════════════════════

# ── Kite Connect API (Ingestion, Aggregator, Tauri) ─────────────────────────
KITE_API_KEY=
KITE_API_SECRET=

# Set KITE_ACCESS_TOKEN directly if you already have a valid token (resets at midnight IST).
# Otherwise set KITE_REQUEST_TOKEN (from OAuth redirect) and the ingestion service will exchange it.
KITE_ACCESS_TOKEN=
KITE_REQUEST_TOKEN=

# ── Sentiment Agent — NewsData.io ───────────────────────────────────────────
# Used by agents/sentiment/src/fetcher.js to pull latest news articles.
NEWSDATA_API_KEY=
# NEWSDATA_PAGE_SIZE=3
# NEWSDATA_LANGUAGE=en

# ── LLM Configuration (Provider-Agnostic) ───────────────────────────────────
# All AI inference uses these three variables. Any OpenAI-compatible API works.
# See .env for provider examples (HuggingFace, OpenAI, Groq, Ollama).
LLM_API_URL=https://router.huggingface.co/v1/chat/completions
LLM_API_KEY=
LLM_MODEL=deepseek-ai/DeepSeek-V3-0324
# LLM_TIMEOUT_SECS=120

# ── Docker Infrastructure ───────────────────────────────────────────────────
# Kafka — used by ingestion, aggregator, technical, predictive, quant-rag, sentiment
KAFKA_BROKER_URL=localhost:19092
KAFKA_BROKERS=localhost:19092
KAFKA_BROKERS_INTERNAL=broker:29092

# QuestDB — used by ingestion (PG + ILP), Tauri (PG for historical queries)
QUESTDB_POSTGRES_URL=postgresql://admin:quest@localhost:8812/qdb
QUESTDB_ILP_ADDR=127.0.0.1:9009
QUESTDB_ILP_ADDR_INTERNAL=questdb:9009

# Redis — used by sentiment agent cache and auth service
REDIS_URL=redis://localhost:6379

# ── Kafka Topics ────────────────────────────────────────────────────────────
KAFKA_TOPIC_SIGNALS=technical_signals
KAFKA_TOPIC_SENTIMENT=sentiment_signals

# ── Service Ports ───────────────────────────────────────────────────────────
WEBSOCKET_PORT=8080
INGESTION_CONTROL_PORT=8085

# ── Auth Service (Identity Vault) ────────────────────────────────────────────
POSTGRES_AUTH_URL=postgresql://auth_admin:auth_secret_dev@localhost:5890/ai_trade_auth
POSTGRES_AUTH_PASSWORD=auth_secret_dev
# CRITICAL: Generate once with `openssl rand -hex 32`. NEVER rotate (invalidates all hashes).
AUTH_PEPPER=
AUTH_PORT=3001

# ── JWT Session Layer ────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
